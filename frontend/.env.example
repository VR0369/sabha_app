# Base URL of the FastAPI backend.
# Leave empty to use the Vite dev proxy (recommended in development).
VITE_API_BASE=

# Google Sign-In — OAuth 2.0 "Web application" Client ID from Google Cloud Console.
# Must match GOOGLE_CLIENT_ID on the backend. If empty, the Google button is
# hidden and only email + password login is shown.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
