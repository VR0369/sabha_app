# --- MongoDB Atlas connection ---
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Then: Database > Connect > Drivers > copy the connection string.
# Replace <username>, <password> and the host below.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=sabha_app

# --- JWT / security ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- First admin bootstrap (created on startup if no users exist) ---
FIRST_ADMIN_NAME=Administrator
FIRST_ADMIN_EMAIL=admin@sabha.app
FIRST_ADMIN_PASSWORD=ChangeMe123!
