# --- MongoDB Atlas connection ---
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# Then: Database > Connect > Drivers > copy the connection string.
# Replace <username>, <password> and the host below.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=sabha_app

# --- JWT / security ---
# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- First admin bootstrap (created on startup if no users exist) ---
FIRST_ADMIN_NAME=Administrator
FIRST_ADMIN_EMAIL=admin@sabha.app
FIRST_ADMIN_PASSWORD=ChangeMe123!

# --- Google Sign-In ---
# Create an OAuth 2.0 "Web application" Client ID in Google Cloud Console
# (APIs & Services > Credentials). Add your frontend origin(s) under
# "Authorized JavaScript origins", e.g. http://localhost:5173 and your prod URL.
# The SAME value must be set as VITE_GOOGLE_CLIENT_ID in the frontend.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# This Google account is always allowed and is granted the admin role.
PRIMARY_ADMIN_EMAIL=vijayrathod1@gmail.com
